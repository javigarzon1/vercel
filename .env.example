# =============================================================
# Variables de entorno necesarias para deploy en Vercel
# =============================================================
# Copia este archivo como .env.local y rellena los valores.
# En Vercel, configúralas en Settings > Environment Variables.
# =============================================================

# ── Supabase (cliente público — se exponen al navegador) ──────
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...

# ── Supabase (servidor — NO se exponen al navegador) ──────────
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Lovable AI Gateway ────────────────────────────────────────
LOVABLE_API_KEY=lv_...
